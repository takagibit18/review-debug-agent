# OpenAI API configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o
# GitHub API (crawler / eval.run crawl). Use a classic PAT or fine-grained PAT with
# "Contents: Read" on target repos and search scope as needed. Also accepted: GH_TOKEN, github_token.
# On Windows, remove any empty/stale GITHUB_TOKEN from User/System env — it used to override .env.
GITHUB_TOKEN=ghp_your_token_for_crawler

# Logging
LOG_LEVEL=INFO

# Orchestrator (optional; defaults match Settings)
# REVIEW_MAX_ITERATIONS=1
# DEBUG_MAX_ITERATIONS=3
# TOKEN_BUDGET=12000
# PROMPT_INPUT_TOKEN_BUDGET=32000
# EVENT_LOG_DIR=.cr-debug-agent/logs
# EVAL_TEMPERATURE=0.0
# EVAL_SAMPLES=1
# EVAL_CONCURRENCY=1
# CI=0
