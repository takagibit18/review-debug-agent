# OpenAI API configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o
# GitHub API (crawler / eval.run crawl). Use a classic PAT or fine-grained PAT with
# "Contents: Read" on target repos and search scope as needed. Also accepted: GH_TOKEN, github_token.
# On Windows, remove any empty/stale GITHUB_TOKEN from User/System env — it used to override .env.
GITHUB_TOKEN=ghp_your_token_for_crawler

# Logging
LOG_LEVEL=INFO

# Orchestrator (optional; defaults match Settings)
# REVIEW_MAX_ITERATIONS=1
# DEBUG_MAX_ITERATIONS=3
# TOKEN_BUDGET=24000         # Soft cap triggers finalize-only; hard cap = 2x.
# FEEDBACK_WINDOW_ITERATIONS=3  # Recent iterations of tool feedback injected verbatim.
# PROMPT_INPUT_TOKEN_BUDGET=32000
# EVENT_LOG_DIR=.mergewarden/logs
#
# Agent trace logging (optional; see docs/agent_trace_logging.md)
# AGENT_TRACE_DETAIL=off
# AGENT_TRACE_MAX_CHARS=1200
# AGENT_TRACE_LOG_TOOL_BODY=false
# EVAL_TEMPERATURE=0.0
# EVAL_SAMPLES=1
# EVAL_CONCURRENCY=1
#
# Execute tools (optional; debug mode only, still gated by high-risk confirmation)
# EXECUTE_ENABLED=true
# EXECUTE_BACKEND=subprocess
# EXECUTE_ALLOWED_COMMANDS=python,pytest,pip,node,npm,ruff,mypy,git
# EXECUTE_DEFAULT_TIMEOUT_MS=30000
# EXECUTE_MAX_OUTPUT_BYTES=65536
#
# Docker execute backend (build Dockerfile.execute first)
# EXECUTE_DOCKER_IMAGE=mergewarden-execute:latest
# EXECUTE_DOCKER_WORKDIR=/workspace
# EXECUTE_DOCKER_NETWORK=none
# EXECUTE_DOCKER_MEMORY_MB=0
# EXECUTE_DOCKER_CPUS=0
#
# Optional smoke tests
# RUN_DOCKER_TESTS=0
# CI=0
